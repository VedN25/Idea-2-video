# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Idea2Video"

# Database (Turso)
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# AI Services
OPENROUTER_API_KEY="sk-or-..."
OPENAI_API_KEY="sk-..."
ELEVENLABS_API_KEY="..."
RUNWAY_API_KEY="..."
LUMA_API_KEY="..."

# Background Jobs (Inngest)
INNGEST_EVENT_KEY="..."
INNGEST_SIGNING_KEY="..."

# Cache/Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Billing (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Video Generation
REMOTION_SERVE_URL="http://localhost:3000"
REMOTION_RENDER_URL="http://localhost:3000"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_VIDEO_GEN="true"
NEXT_PUBLIC_ENABLE_COLLABORATION="false"
NEXT_PUBLIC_ENABLE_BRAND_KIT="false"